{
  "name": "auditor-calidad-iso",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "test:shared": "pnpm --filter @auditor/shared test",
    "test:analyzer": "pnpm --filter @auditor/analyzer test",
    "test:report": "pnpm --filter @auditor/report-generator test",
    "test:ingesta": "pnpm --filter @auditor/ingesta test",
    "build:frontend": "pnpm --filter @auditor/frontend build",
    "dev:frontend": "pnpm --filter @auditor/frontend dev",
    "deploy": "cd infra && sam build && sam deploy",
    "deploy:guided": "cd infra && sam build && sam deploy --guided",
    "validate": "cd infra && sam validate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "pnpm": "^11.15.1",
    "typescript": "^5.5.0"
  }
}
